#!/bin/bash
# relay-bridge -- Start voice I/O pipeline (STT sidecar + voice bridge).
#
# Usage:
#   relay-bridge                     # Normal mode: full voice terminal
#   relay-bridge --session <id>      # Resume a specific Claude session
#   relay-bridge --relay             # Relay mode: daemon for /relay-bridge slash command
#   relay-bridge --venv-only         # Run venv bootstrap and exit 0 (used by onboarding)
#
# In relay mode, voice commands are written to /tmp/voice_cmd_ready for Claude
# to pick up, and TTS input is read from /tmp/tts_in.fifo.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# -- Paths --
SERVICES_DIR="$PROJECT_ROOT/services"
VOICE_FIFO="/tmp/voice_in.fifo"
BRIDGE_SOCK="/tmp/voice_bridge.sock"

CONFIG_DIR="${XDG_CONFIG_HOME:-}"
if [ -z "$CONFIG_DIR" ]; then
    if [ "$(uname)" = "Darwin" ]; then
        CONFIG_DIR="$HOME/Library/Application Support"
    else
        CONFIG_DIR="$HOME/.config"
    fi
fi
CONFIG_PATH="$CONFIG_DIR/relay-runner/config.toml"

# Export PROJECT_ROOT so the slash command can find us
export PROJECT_ROOT

# -- Parse our own flags before passing the rest to voice_bridge.py --
# --venv-only: run only the venv bootstrap below, then exit. Used by
# the app's onboarding flow so it can call into the same battle-tested
# Python setup that interactive /relay-bridge sessions use, with output
# streamed back to the SwiftUI progress view.
VENV_ONLY=false

# Emit a progress marker the SwiftUI installer can parse to drive a
# determinate progress bar. Format: `RELAY_PROGRESS:<percent>:<label>`.
# Percent is 0–100, label is a short human-readable description of the
# current phase. Interactive callers see the same line as plain output;
# the SwiftUI side strips the `RELAY_PROGRESS:` prefix and treats the
# rest as structured. Keep labels short — they show up under a progress
# bar with limited horizontal space.
emit_progress() {
    echo "RELAY_PROGRESS:$1:$2"
}
__rb_args=()
for arg in "$@"; do
    case "$arg" in
        --venv-only) VENV_ONLY=true ;;
        *) __rb_args+=("$arg") ;;
    esac
done
# Re-bind $@ to the filtered list so the final exec sees only flags
# voice_bridge.py understands. The +/expansion guards against `set -u`
# when no args remain (bash 3.2 compatibility).
set -- "${__rb_args[@]+"${__rb_args[@]}"}"

# -- Kill any existing bridge (only one voice session at a time) --
# Skipped under --venv-only so onboarding doesn't tear down a running
# session just to install dependencies in the background.
if ! $VENV_ONLY && [ -S "$BRIDGE_SOCK" ]; then
    if pgrep -f 'voice_bridge.py' > /dev/null 2>&1; then
        echo "[relay-bridge] Stopping previous voice session..."
        # Try graceful shutdown first
        python3 -c "
import socket, os
s = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
try: s.sendto(b'shutdown', '$BRIDGE_SOCK')
except: pass
s.close()
" 2>/dev/null
        sleep 0.5
        # Force kill if still alive
        pkill -f 'voice_bridge.py' 2>/dev/null || true
        sleep 0.3
    fi
    rm -f "$BRIDGE_SOCK"
fi

# -- Ensure Python venv with dependencies --
PYTHON="$SERVICES_DIR/.venv/bin/python3"
# Re-run setup if the venv is missing OR if a prior setup left the venv
# in place but failed to install deps — otherwise we'd exec a venv python
# with no numpy/kokoro_onnx/huggingface_hub and crash at import or first
# model-download time. huggingface_hub must be verified explicitly:
# kokoro-onnx imports cleanly without it, then fails when tts_worker
# tries to download models.
if ! "$PYTHON" -c 'import numpy, kokoro_onnx, huggingface_hub' >/dev/null 2>&1; then
    echo ''
    echo '╔══════════════════════════════════════════╗'
    echo '║  Relay Runner — First-time setup         ║'
    echo '║  Installing Python dependencies...       ║'
    echo '╚══════════════════════════════════════════╝'
    echo ''
    emit_progress 5 "Locating Python..."
    # Prefer a specific minor version with broad wheel coverage for our
    # deps (kokoro-onnx + transitive phonemizer/espeakng/onnxruntime).
    # kokoro-onnx caps at Python <3.14, so the bare `python3` on newer
    # Homebrew (→ 3.14) is *not* acceptable here — we'd rather fall
    # through and auto-install python@3.13 via Homebrew.
    find_python() {
        for p in \
            /opt/homebrew/bin/python3.13 /usr/local/bin/python3.13 python3.13 \
            /opt/homebrew/bin/python3.12 /usr/local/bin/python3.12 python3.12 \
            /opt/homebrew/bin/python3.11 /usr/local/bin/python3.11 python3.11 \
            /opt/homebrew/bin/python3 /usr/local/bin/python3 python3; do
            if command -v "$p" >/dev/null 2>&1 && \
               "$p" -c 'import sys; sys.exit(0 if (3,10) <= sys.version_info[:2] <= (3,13) else 1)' 2>/dev/null; then
                echo "$p"
                return 0
            fi
        done
        return 1
    }
    find_brew() {
        for b in brew /opt/homebrew/bin/brew /usr/local/bin/brew; do
            if command -v "$b" >/dev/null 2>&1; then
                echo "$b"
                return 0
            fi
        done
        return 1
    }
    install_homebrew() {
        if ! command -v curl >/dev/null 2>&1; then
            echo "[Relay Runner] curl not available — cannot bootstrap Homebrew."
            return 1
        fi
        emit_progress 15 "Installing Homebrew (may take several minutes)..."
        echo "[Relay Runner] Homebrew not found. Installing Homebrew..."
        echo "(This may prompt for your macOS password.)"
        NONINTERACTIVE=1 /bin/bash -c \
            "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" || return 1
        # Bring brew onto PATH for the rest of this shell.
        for b in /opt/homebrew/bin/brew /usr/local/bin/brew; do
            if [ -x "$b" ]; then
                eval "$("$b" shellenv)"
                return 0
            fi
        done
        return 1
    }
    # If an existing venv was built with an out-of-range Python (e.g.
    # 3.14, which kokoro-onnx doesn't support), wipe it so the block
    # below creates a fresh venv with a supported interpreter.
    if [ -x "$PYTHON" ] && \
       ! "$PYTHON" -c 'import sys; sys.exit(0 if (3,10) <= sys.version_info[:2] <= (3,13) else 1)' 2>/dev/null; then
        echo "[Relay Runner] Existing venv uses $("$PYTHON" -c 'import sys; print(".".join(map(str, sys.version_info[:2])))'), which kokoro-onnx doesn't support. Recreating with a 3.10–3.13 interpreter."
        rm -rf "$SERVICES_DIR/.venv"
    fi
    # Only create a new venv if one isn't already on disk; if the venv
    # exists but deps are missing, we fall through to reinstall into the
    # existing interpreter.
    if [ ! -x "$PYTHON" ]; then
        VENV_PYTHON="$(find_python || true)"
        if [ -z "$VENV_PYTHON" ]; then
            BREW="$(find_brew || true)"
            if [ -z "$BREW" ]; then
                if ! install_homebrew; then
                    echo "[Relay Runner] Could not install Homebrew automatically."
                    echo "Install it from https://brew.sh then re-run."
                    exit 1
                fi
                BREW="$(find_brew || true)"
            fi
            emit_progress 30 "Installing Python 3.13 via Homebrew..."
            echo "[Relay Runner] No Python 3.10+ found. Installing python@3.13 via Homebrew..."
            echo "(This can take a few minutes on first run.)"
            if ! "$BREW" install python@3.13; then
                echo "[Relay Runner] brew install python@3.13 failed. See errors above."
                exit 1
            fi
            VENV_PYTHON="$(find_python || true)"
            if [ -z "$VENV_PYTHON" ]; then
                echo "[Relay Runner] python@3.13 installed but not found on disk."
                echo "Try opening a new terminal and re-running."
                exit 1
            fi
        fi
        emit_progress 50 "Creating virtual environment..."
        echo "Using $("$VENV_PYTHON" --version) at $VENV_PYTHON"
        "$VENV_PYTHON" -m venv "$SERVICES_DIR/.venv" || {
            echo "[Relay Runner] Failed to create venv."
            exit 1
        }
    else
        echo "[Relay Runner] Venv present but deps incomplete — reinstalling."
    fi
    emit_progress 60 "Upgrading pip..."
    "$SERVICES_DIR/.venv/bin/python3" -m pip install --upgrade pip || \
        { echo ''; echo '[Relay Runner] Setup failed. Check errors above.'; exit 1; }
    # Pip emits one "Collecting <pkg>" line per (transitive) dep before
    # the silent download phase. The Swift parser ticks the bar within
    # the 65–95% band each time it sees one — that's where the perceived
    # hang lives, so the sub-progress is what makes the bar feel alive.
    emit_progress 65 "Installing numpy, onnxruntime, kokoro-onnx, huggingface_hub..."
    "$SERVICES_DIR/.venv/bin/pip" install -r "$SERVICES_DIR/requirements.txt" || \
        { echo ''; echo '[Relay Runner] Setup failed. Check errors above.'; exit 1; }
    emit_progress 100 "Setup complete."
    echo ''
    echo '[Relay Runner] Setup complete.'
    echo ''
fi

# -- Onboarding short-circuit: bootstrap is done, no voice bridge needed --
if $VENV_ONLY; then
    # Emit a terminal 100% marker so the SwiftUI bar fills regardless of
    # whether the install block above ran or was short-circuited (venv
    # already healthy on a re-run).
    emit_progress 100 "Ready."
    echo '[relay-bridge] Venv ready (--venv-only).'
    exit 0
fi

# -- Create FIFO --
[ -p "$VOICE_FIFO" ] || mkfifo "$VOICE_FIFO" 2>/dev/null || true

# -- Note: STT is now handled by the Relay Runner menu bar app --
# -- This script only starts the Python voice bridge in relay mode --
if ! pgrep -f 'relay-runner' > /dev/null 2>&1; then
    echo "[relay-bridge] Warning: Relay Runner app is not running. STT will not be available."
    echo "[relay-bridge] Start the Relay Runner menu bar app for speech-to-text."
fi

# -- Start voice bridge --
echo "[relay-bridge] Starting voice bridge..."
exec "$PYTHON" "$SERVICES_DIR/voice_bridge.py" --config "$CONFIG_PATH" --relay "$@"
