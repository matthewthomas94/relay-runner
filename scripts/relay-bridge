#!/bin/bash
# relay-bridge -- Start voice I/O pipeline (STT sidecar + voice bridge).
#
# Usage:
#   relay-bridge                     # Normal mode: full voice terminal
#   relay-bridge --session <id>      # Resume a specific Claude session
#   relay-bridge --relay             # Relay mode: daemon for /relay-bridge slash command
#   relay-bridge --venv-only         # Run venv bootstrap and exit 0 (used by onboarding)
#   relay-bridge --install-skills    # Force-write Claude Code slash command files and exit 0
#
# In relay mode, voice commands are written to /tmp/voice_cmd_ready for Claude
# to pick up, and TTS input is read from /tmp/tts_in.fifo.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# -- Paths --
# Read-only services bundled inside the .app (or repo, for dev): the
# Python source files and requirements.txt that ship with each release.
SERVICES_BUNDLE="$PROJECT_ROOT/services"
# Writable runtime data — venv + downloaded Python live here so the
# install path works for non-admin users with no Homebrew or system
# Python. Admin is required to install Homebrew or run macOS package
# installers, but ~/Library is always user-writable.
USER_DATA_DIR="$HOME/Library/Application Support/relay-runner"
SERVICES_DIR="$USER_DATA_DIR/services"
RELOCATABLE_PYTHON_DIR="$USER_DATA_DIR/python"
RELOCATABLE_PYTHON="$RELOCATABLE_PYTHON_DIR/bin/python3"
mkdir -p "$SERVICES_DIR"
VOICE_FIFO="/tmp/voice_in.fifo"
BRIDGE_SOCK="/tmp/voice_bridge.sock"

CONFIG_DIR="${XDG_CONFIG_HOME:-}"
if [ -z "$CONFIG_DIR" ]; then
    if [ "$(uname)" = "Darwin" ]; then
        CONFIG_DIR="$HOME/Library/Application Support"
    else
        CONFIG_DIR="$HOME/.config"
    fi
fi
CONFIG_PATH="$CONFIG_DIR/relay-runner/config.toml"

# Export PROJECT_ROOT so the slash command can find us
export PROJECT_ROOT

# -- Parse our own flags before passing the rest to voice_bridge.py --
# --venv-only: run only the venv bootstrap below, then exit. Used by
# the app's onboarding flow so it can call into the same battle-tested
# Python setup that interactive /relay-bridge sessions use, with output
# streamed back to the SwiftUI progress view.
# --install-skills: write ~/.claude/commands/relay-bridge.md and
# relay-stop.md, then exit. Used by Settings → Install Skill so the .md
# template content lives here as a single source of truth instead of
# being duplicated as Swift literals.
VENV_ONLY=false
INSTALL_SKILLS_ONLY=false

# Emit a progress marker the SwiftUI installer can parse to drive a
# determinate progress bar. Format: `RELAY_PROGRESS:<percent>:<label>`.
# Percent is 0–100, label is a short human-readable description of the
# current phase. Interactive callers see the same line as plain output;
# the SwiftUI side strips the `RELAY_PROGRESS:` prefix and treats the
# rest as structured. Keep labels short — they show up under a progress
# bar with limited horizontal space.
#
# Writes to stderr so it doesn't contaminate functions whose stdout
# the caller captures (e.g. `find_python`, `ensure_relocatable_python`).
# The SwiftUI parser merges stdout + stderr into one pipe, so it still
# sees these lines.
emit_progress() {
    echo "RELAY_PROGRESS:$1:$2" >&2
}

# Write the two Claude Code slash-command files into ~/.claude/commands.
# Mode "if-missing" (default) only writes a file if it doesn't already
# exist, so the bootstrap path can't silently clobber a user's local
# edits to the .md. Mode "force" always overwrites — used by the
# explicit Settings → Reinstall action.
#
# The bridge skill embeds the absolute path to *this* script so Claude
# Code can launch the relay daemon directly. Using $SCRIPT_DIR (rather
# than $PATH) keeps the skill working when the user's shell profile
# doesn't surface the bundled relay-bridge.
install_skills() {
    local mode="${1:-if-missing}"
    local cmds_dir="$HOME/.claude/commands"
    local bridge_md="$cmds_dir/relay-bridge.md"
    local stop_md="$cmds_dir/relay-stop.md"
    local relay_bridge_path="$SCRIPT_DIR/relay-bridge"

    mkdir -p "$cmds_dir"

    if [ "$mode" = "force" ] || [ ! -f "$bridge_md" ]; then
        # Quoted heredoc — no $-expansion. The single placeholder
        # __RELAY_BRIDGE__ gets sed-substituted below so the path lands
        # in the .md verbatim.
        cat > "$bridge_md" <<'BRIDGE_MD_EOF'
Connect voice I/O to this Claude session. You become a voice-interactive assistant: listen for spoken input, respond, and speak the response aloud via TTS.

## Setup

1. Verify the Relay Runner app is running:

```bash
pgrep -f 'relay-runner' > /dev/null 2>&1 && echo "app: ok" || echo "app: NOT RUNNING"
```

If not running, tell the user to start the Relay Runner menu bar app, then try `/relay-bridge` again. Do not proceed.

2. Kill any existing voice bridge and start a new one in relay mode. The bundled `relay-bridge` script handles its own venv install (relocatable Python, pip deps, Kokoro speech model) and short-circuits when everything's already set up; on first run it may take a couple of minutes downloading deps:

```bash
pkill -f 'voice_bridge.py' 2>/dev/null; rm -f /tmp/voice_bridge.sock /tmp/voice_cmd_ready /tmp/voice_bridge_heartbeat
nohup '__RELAY_BRIDGE__' --relay > /tmp/voice_bridge.log 2>&1 &
```

3. Wait for the relay bridge to come up. The 60-iteration cap is generous on purpose: the very first invocation may need to download a Python interpreter (~18 MB) and the Kokoro speech model (~350 MB) before the bridge can listen, so allow ~30 seconds:

```bash
for i in $(seq 1 60); do [ -S /tmp/voice_bridge.sock ] && echo "bridge: ok" && break; sleep 0.5; done; [ -S /tmp/voice_bridge.sock ] || echo "bridge: FAILED"
```

If the bridge failed to start, tell the user to check `/tmp/voice_bridge.log` and stop here.

## Voice Interaction Loop

Now enter a continuous loop. Repeat these steps until the user says "stop listening" or you receive `__INTERRUPT__`:

### Step 1: Wait for voice input

```bash
while [ ! -f /tmp/voice_cmd_ready ]; do sleep 0.2; touch /tmp/voice_bridge_heartbeat; [ -S /tmp/voice_bridge.sock ] || { echo "__BRIDGE_DIED__"; exit 0; }; done; cat /tmp/voice_cmd_ready; rm -f /tmp/voice_cmd_ready
```

This blocks until the user speaks via Caps Lock. If the voice bridge is killed (e.g. a new session was started), the loop exits.

### Step 2: Process the input

- If the text is `__BRIDGE_DIED__`, the voice session was ended (another session was started, or the bridge was stopped). Say "Voice session ended." and stop the loop — do NOT go back to Step 1. Clean up and return to normal operation.
- If the text is `__INTERRUPT__`, **silently** go back to Step 1. Do NOT generate any text response, do NOT write to `/tmp/tts_in.fifo`, do NOT acknowledge in any user-visible way. Cancel means the user wants silence — speaking again would just give them another message to cancel, which loops.
- Otherwise, treat the text as a normal user message. Respond naturally and helpfully, as you would to any typed message.

### Step 3: Speak your response

After generating your response, ensure the bridge is still alive (the app's watchdog may have killed an orphaned bridge during long processing). If it died, restart it via the bundled relay-bridge so the user still receives your response:

```bash
touch /tmp/voice_bridge_heartbeat
if ! pgrep -f 'voice_bridge.py' > /dev/null 2>&1; then
    rm -f /tmp/voice_bridge.sock
    nohup '__RELAY_BRIDGE__' --relay > /tmp/voice_bridge.log 2>&1 &
    for i in $(seq 1 20); do [ -S /tmp/voice_bridge.sock ] && break; sleep 0.5; done
fi
```

Then send the TTS response. Keep it concise and conversational (strip markdown formatting, code blocks, and verbose explanations — speak the key points):

```bash
echo 'YOUR_SPOKEN_RESPONSE' > /tmp/tts_in.fifo
```

Important: Use single quotes and escape any single quotes in your response (`'` becomes `'\''`). Only send the spoken summary, not the full detailed response.

### Step 4: Loop

Go back to Step 1 and wait for the next voice command.

## Cleanup

When the session ends (user says "stop listening", "exit voice", or similar), clean up:

```bash
pkill -f 'voice_bridge.py' 2>/dev/null; rm -f /tmp/voice_bridge.sock /tmp/voice_cmd_ready /tmp/voice_bridge_heartbeat
```

## Important Notes

- You are in a normal Claude session with full tool access. Voice input is just another way for the user to send messages.
- Speak concisely. TTS responses should be 1-3 sentences summarizing what you did or what you found. The user can read the full detail in the conversation.
- If the user asks you to run commands, edit files, or do anything you'd normally do, do it. Then speak a brief summary of what happened.
- The relay daemon handles Caps Lock detection, STT, and TTS playback. You just read commands and write responses.
BRIDGE_MD_EOF
        # Substitute the relay-bridge absolute path. Use | as the sed
        # delimiter so / in $relay_bridge_path doesn't conflict.
        # In-place edit via tmp file (BSD/macOS sed -i takes a backup
        # suffix arg, GNU doesn't — round-trip via mv is portable).
        local tmp="$bridge_md.tmp"
        sed "s|__RELAY_BRIDGE__|$relay_bridge_path|g" "$bridge_md" > "$tmp" && mv "$tmp" "$bridge_md"
    fi

    if [ "$mode" = "force" ] || [ ! -f "$stop_md" ]; then
        cat > "$stop_md" <<'STOP_MD_EOF'
Stop the voice I/O bridge for this Claude session. Use this to end a `/relay-bridge` voice session cleanly without exiting Claude Code.

## Steps

1. Kill the voice bridge process and remove its runtime files:

```bash
pkill -f 'voice_bridge.py' 2>/dev/null; rm -f /tmp/voice_bridge.sock /tmp/voice_cmd_ready /tmp/voice_bridge_heartbeat
```

2. Confirm it's stopped:

```bash
pgrep -f 'voice_bridge.py' > /dev/null 2>&1 && echo "bridge: STILL RUNNING" || echo "bridge: stopped"
```

If the bridge is still running, tell the user to check `/tmp/voice_bridge.log` and try again. Otherwise, tell the user the voice session has ended.

## Notes

- This only stops the voice bridge. The Relay Runner menu bar app keeps running.
- Any active `/relay-bridge` voice loop in another Claude session will detect the dead socket on its next heartbeat and exit on its own.
- To start voice again, run `/relay-bridge`.
STOP_MD_EOF
    fi
}

__rb_args=()
for arg in "$@"; do
    case "$arg" in
        --venv-only) VENV_ONLY=true ;;
        --install-skills) INSTALL_SKILLS_ONLY=true ;;
        *) __rb_args+=("$arg") ;;
    esac
done
# Re-bind $@ to the filtered list so the final exec sees only flags
# voice_bridge.py understands. The +/expansion guards against `set -u`
# when no args remain (bash 3.2 compatibility).
set -- "${__rb_args[@]+"${__rb_args[@]}"}"

# -- Skill-only path: write the .md files and exit, no bootstrap. --
# Used by Settings → Install Skill (force overwrite — the user already
# confirmed they want to replace any existing files).
if $INSTALL_SKILLS_ONLY; then
    install_skills force
    echo "[relay-bridge] Installed Claude Code skills at $HOME/.claude/commands/relay-bridge.md and relay-stop.md."
    exit 0
fi

# -- Kill any existing bridge (only one voice session at a time) --
# Skipped under --venv-only so onboarding doesn't tear down a running
# session just to install dependencies in the background.
if ! $VENV_ONLY && [ -S "$BRIDGE_SOCK" ]; then
    if pgrep -f 'voice_bridge.py' > /dev/null 2>&1; then
        echo "[relay-bridge] Stopping previous voice session..."
        # Try graceful shutdown first
        python3 -c "
import socket, os
s = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
try: s.sendto(b'shutdown', '$BRIDGE_SOCK')
except: pass
s.close()
" 2>/dev/null
        sleep 0.5
        # Force kill if still alive
        pkill -f 'voice_bridge.py' 2>/dev/null || true
        sleep 0.3
    fi
    rm -f "$BRIDGE_SOCK"
fi

# -- Ensure Python venv with dependencies AND speech-model files --
# Two separate things have to be true for the voice bridge to work:
#   1. Python venv exists with numpy / kokoro_onnx / huggingface_hub
#   2. Kokoro speech-model files (~350 MB) are on disk
# Old code only checked (1), so the user could finish onboarding and then
# discover the first session was silent because tts_worker.py was lazy-
# downloading models — and would simply fail if the network was flaky
# at that moment. We now check both up front and pre-download the
# models as part of the install, so a successful onboarding means the
# session works immediately, fully offline.
PYTHON="$SERVICES_DIR/.venv/bin/python3"
# Match what tts_worker.py:_find_kokoro_model() looks for.
KOKORO_DIR="$HOME/.local/share/kokoro"
KOKORO_MODEL_FILE="$KOKORO_DIR/kokoro-v1.0.onnx"
KOKORO_VOICES_FILE="$KOKORO_DIR/voices-v1.0.bin"

PYTHON_DEPS_OK=false
"$PYTHON" -c 'import numpy, kokoro_onnx, huggingface_hub' >/dev/null 2>&1 && PYTHON_DEPS_OK=true
KOKORO_MODELS_OK=false
[ -f "$KOKORO_MODEL_FILE" ] && [ -f "$KOKORO_VOICES_FILE" ] && KOKORO_MODELS_OK=true
# voice_bridge.py spawns the Claude Code CLI when started without --relay
# (each spoken turn shells out to `claude -p ...`). If the binary isn't
# present a session falls over with "claude not found on PATH" the
# moment the user clicks Start Session — no visible progress bar, just a
# dead terminal. claude.ai/install.sh symlinks the binary to
# ~/.local/bin/claude (~/.local/share/claude/versions/X.Y.Z is the real
# binary), so check both PATH and that canonical fallback location.
CLAUDE_CLI_OK=false
{ command -v claude >/dev/null 2>&1 || [ -x "$HOME/.local/bin/claude" ]; } && CLAUDE_CLI_OK=true
# The /relay-bridge and /relay-stop slash commands live as .md files
# under ~/.claude/commands. They're how the user invokes a voice loop
# from inside an existing Claude Code session — without them, voice
# input only works via the menu bar's Start Session path. Mirror the
# Claude CLI gate so missing files trigger a write during the same
# bootstrap run; the actual install step below runs *after* the CLI
# install so the .md commands always reference a working `claude`.
RELAY_SKILLS_OK=false
[ -f "$HOME/.claude/commands/relay-bridge.md" ] && [ -f "$HOME/.claude/commands/relay-stop.md" ] && RELAY_SKILLS_OK=true
# The Relay Actions MCP server (relay-actions-mcp) gives Claude
# screenshot + click/type tools for UAT and dashboard automation, gated
# by hardware double-tap confirmation. Registered into Claude Code at
# user scope (~/.claude.json) so it's available in every working dir,
# not just this project. Check uses `claude mcp get` which exits 0 when
# the named server is registered. Skipped here if the CLI isn't present
# yet — the install block below registers it after installing the CLI.
RELAY_MCP_OK=false
if [ -x "$HOME/.local/bin/claude" ] || command -v claude >/dev/null 2>&1; then
    if [ -x "$HOME/.local/bin/claude" ]; then
        __claude_for_check="$HOME/.local/bin/claude"
    else
        __claude_for_check="$(command -v claude)"
    fi
    "$__claude_for_check" mcp get relay-actions >/dev/null 2>&1 && RELAY_MCP_OK=true
fi

if ! $PYTHON_DEPS_OK || ! $KOKORO_MODELS_OK || ! $CLAUDE_CLI_OK || ! $RELAY_SKILLS_OK || ! $RELAY_MCP_OK; then
    echo ''
    echo '╔══════════════════════════════════════════╗'
    echo '║  Relay Runner — First-time setup         ║'
    echo '║  Installing Python dependencies...       ║'
    echo '╚══════════════════════════════════════════╝'
    echo ''
    emit_progress 5 "Locating Python..."
    # Prefer a specific minor version with broad wheel coverage for our
    # deps (kokoro-onnx + transitive phonemizer/espeakng/onnxruntime).
    # kokoro-onnx caps at Python <3.14, so the bare `python3` on newer
    # Homebrew (→ 3.14) is *not* acceptable here — we'd rather fall
    # through and auto-install python@3.13 via Homebrew.
    find_python() {
        for p in \
            /opt/homebrew/bin/python3.13 /usr/local/bin/python3.13 python3.13 \
            /opt/homebrew/bin/python3.12 /usr/local/bin/python3.12 python3.12 \
            /opt/homebrew/bin/python3.11 /usr/local/bin/python3.11 python3.11 \
            /opt/homebrew/bin/python3 /usr/local/bin/python3 python3; do
            if command -v "$p" >/dev/null 2>&1 && \
               "$p" -c 'import sys; sys.exit(0 if (3,10) <= sys.version_info[:2] <= (3,13) else 1)' 2>/dev/null; then
                echo "$p"
                return 0
            fi
        done
        return 1
    }
    # Download a relocatable Python 3.13 build into RELOCATABLE_PYTHON_DIR
    # and echo the interpreter path. Used when no system Python in the
    # 3.10–3.13 range exists. python-build-standalone is the same
    # distribution uv / Rye / pyodide use; it's PSF-licensed (with
    # statically-linked OpenSSL etc.), extracts cleanly into any user-
    # writable directory, and crucially does NOT require admin (the
    # previous Homebrew-bootstrap path did, which broke for non-admin
    # users). Idempotent: skips the download if a usable interpreter
    # already lives at RELOCATABLE_PYTHON.
    ensure_relocatable_python() {
        if [ -x "$RELOCATABLE_PYTHON" ] && \
           "$RELOCATABLE_PYTHON" -c 'import sys; sys.exit(0 if (3,10) <= sys.version_info[:2] <= (3,13) else 1)' 2>/dev/null; then
            echo "$RELOCATABLE_PYTHON"
            return 0
        fi
        if ! command -v curl >/dev/null 2>&1; then
            echo "[Relay Runner] curl not available — cannot download Python." >&2
            return 1
        fi
        local arch
        case "$(uname -m)" in
            arm64)  arch="aarch64-apple-darwin" ;;
            x86_64) arch="x86_64-apple-darwin" ;;
            *)
                echo "[Relay Runner] Unsupported architecture: $(uname -m)" >&2
                return 1
                ;;
        esac
        emit_progress 25 "Downloading Python 3.13 (~18MB, no admin required)..."
        # Stderr only — function's stdout is captured by the caller as
        # the path to the interpreter, so anything else printed there
        # gets concatenated into $VENV_PYTHON and breaks downstream.
        echo "[Relay Runner] No system Python 3.10–3.13 found — downloading" >&2
        echo "[Relay Runner] a standalone Python 3.13 build (no admin required)." >&2

        # Find the latest 3.13 install_only asset URL via GitHub's API.
        # Asset name pattern (literal `+`, URL-encoded as %2B in JSON):
        #   cpython-3.13.X+YYYYMMDD-<arch>-install_only.tar.gz
        # `install_only` is the slimmer embedding-friendly variant;
        # `freethreaded` is the GIL-less PEP 703 build, not what we want.
        # `|| true` guards against pipefail when grep finds nothing.
        local api_url="https://api.github.com/repos/astral-sh/python-build-standalone/releases/latest"
        local asset_url
        asset_url=$(curl -fsSL "$api_url" 2>/dev/null \
            | grep -oE '"browser_download_url": "[^"]*'"$arch"'-install_only\.tar\.gz"' \
            | grep -E 'cpython-3\.13\.' \
            | grep -v 'freethreaded' \
            | head -1 \
            | sed -E 's/.*"([^"]+)"/\1/' || true)
        if [ -z "$asset_url" ]; then
            echo "[Relay Runner] Couldn't locate a python-build-standalone 3.13 release for $arch." >&2
            echo "[Relay Runner] Check internet connectivity, or rate-limit on api.github.com." >&2
            return 1
        fi
        # SHA256SUMS file lives at the same release base path; the file
        # lists the literal asset name, but the URL we got back from the
        # API has `%2B` for `+` — decode for the lookup.
        local checksums_url="${asset_url%/*}/SHA256SUMS"
        local asset_name="${asset_url##*/}"
        asset_name="${asset_name//%2B/+}"

        # Stage download + extract inside USER_DATA_DIR so the final mv
        # is a same-filesystem rename (atomic). mktemp -d ensures we
        # never collide with a parallel install.
        mkdir -p "$USER_DATA_DIR"
        local stage
        stage=$(mktemp -d "$USER_DATA_DIR/.python-stage.XXXXXX") || return 1

        local tmp_tar="$stage/python.tar.gz"
        if ! curl -fsSL "$asset_url" -o "$tmp_tar"; then
            rm -rf "$stage"
            echo "[Relay Runner] Python download failed." >&2
            return 1
        fi

        # Verify SHA256 against the release's SHA256SUMS file. Refuse
        # to install if the checksum is missing or mismatched — better
        # to fail loudly than silently install a corrupted interpreter.
        local expected_sha
        expected_sha=$(curl -fsSL "$checksums_url" 2>/dev/null \
            | awk -v name="$asset_name" '$2 == name { print $1; exit }' || true)
        if [ -z "$expected_sha" ]; then
            rm -rf "$stage"
            echo "[Relay Runner] Couldn't fetch SHA256 checksum for verification." >&2
            return 1
        fi
        local actual_sha
        actual_sha=$(shasum -a 256 "$tmp_tar" | awk '{print $1}')
        if [ "$expected_sha" != "$actual_sha" ]; then
            rm -rf "$stage"
            echo "[Relay Runner] Python checksum mismatch — refusing to install." >&2
            echo "  Expected: $expected_sha" >&2
            echo "  Got:      $actual_sha" >&2
            return 1
        fi

        emit_progress 40 "Extracting Python..."
        if ! tar -xzf "$tmp_tar" -C "$stage"; then
            rm -rf "$stage"
            echo "[Relay Runner] Failed to extract Python tarball." >&2
            return 1
        fi
        # Tarball unpacks into a top-level "python/" directory.
        if [ ! -x "$stage/python/bin/python3" ]; then
            rm -rf "$stage"
            echo "[Relay Runner] Extracted Python missing expected interpreter." >&2
            return 1
        fi

        # Atomically replace any existing install. Move the old aside
        # so we can restore on failure rather than leaving the user
        # with no Python at all.
        if [ -e "$RELOCATABLE_PYTHON_DIR" ]; then
            rm -rf "$RELOCATABLE_PYTHON_DIR.old"
            mv "$RELOCATABLE_PYTHON_DIR" "$RELOCATABLE_PYTHON_DIR.old"
        fi
        if ! mv "$stage/python" "$RELOCATABLE_PYTHON_DIR"; then
            if [ -e "$RELOCATABLE_PYTHON_DIR.old" ]; then
                mv "$RELOCATABLE_PYTHON_DIR.old" "$RELOCATABLE_PYTHON_DIR" 2>/dev/null || true
            fi
            rm -rf "$stage"
            echo "[Relay Runner] Failed to install downloaded Python." >&2
            return 1
        fi
        rm -rf "$RELOCATABLE_PYTHON_DIR.old" "$stage"

        if [ ! -x "$RELOCATABLE_PYTHON" ]; then
            echo "[Relay Runner] Python install completed but interpreter missing at $RELOCATABLE_PYTHON" >&2
            return 1
        fi

        echo "$RELOCATABLE_PYTHON"
    }
    if ! $PYTHON_DEPS_OK; then
        # If an existing venv was built with an out-of-range Python (e.g.
        # 3.14, which kokoro-onnx doesn't support), wipe it so the block
        # below creates a fresh venv with a supported interpreter.
        if [ -x "$PYTHON" ] && \
           ! "$PYTHON" -c 'import sys; sys.exit(0 if (3,10) <= sys.version_info[:2] <= (3,13) else 1)' 2>/dev/null; then
            echo "[Relay Runner] Existing venv uses $("$PYTHON" -c 'import sys; print(".".join(map(str, sys.version_info[:2])))'), which kokoro-onnx doesn't support. Recreating with a 3.10–3.13 interpreter."
            rm -rf "$SERVICES_DIR/.venv"
        fi
        # Only create a new venv if one isn't already on disk; if the venv
        # exists but deps are missing, we fall through to reinstall into the
        # existing interpreter.
        if [ ! -x "$PYTHON" ]; then
            # Test override — flip to force the relocatable-Python path even
            # on a machine that has a system Python in our range, so we can
            # exercise the no-admin install end-to-end without uninstalling
            # the system interpreter.
            if [ -n "${RELAY_FORCE_RELOCATABLE_PYTHON:-}" ]; then
                VENV_PYTHON=""
            else
                VENV_PYTHON="$(find_python || true)"
            fi
            if [ -z "$VENV_PYTHON" ]; then
                VENV_PYTHON="$(ensure_relocatable_python || true)"
                if [ -z "$VENV_PYTHON" ]; then
                    echo "[Relay Runner] Could not obtain a usable Python 3.10–3.13 interpreter."
                    echo "[Relay Runner] See errors above; fix and re-launch Relay Runner."
                    exit 1
                fi
            fi
            emit_progress 50 "Creating virtual environment..."
            echo "Using $("$VENV_PYTHON" --version) at $VENV_PYTHON"
            "$VENV_PYTHON" -m venv "$SERVICES_DIR/.venv" || {
                echo "[Relay Runner] Failed to create venv."
                exit 1
            }
        else
            echo "[Relay Runner] Venv present but deps incomplete — reinstalling."
        fi
        emit_progress 60 "Upgrading pip..."
        "$SERVICES_DIR/.venv/bin/python3" -m pip install --upgrade pip || \
            { echo ''; echo '[Relay Runner] Setup failed. Check errors above.'; exit 1; }
        # Pip emits one "Collecting <pkg>" line per (transitive) dep before
        # the silent download phase. The Swift parser ticks the bar within
        # the dep-install band each time it sees one — that's where the
        # perceived "hang" lives, so the sub-progress is what makes the
        # bar feel alive.
        emit_progress 65 "Installing numpy, onnxruntime, kokoro-onnx, huggingface_hub..."
        "$SERVICES_DIR/.venv/bin/pip" install -r "$SERVICES_BUNDLE/requirements.txt" || \
            { echo ''; echo '[Relay Runner] Setup failed. Check errors above.'; exit 1; }
    fi

    if ! $KOKORO_MODELS_OK; then
        # Pre-download the Kokoro speech model + voices (~350 MB) so the
        # first session works immediately. tts_worker.py:_load_voice
        # has lazy-download fallback logic, but a pre-downloaded model
        # means the user never sees TTS silently fail or hang on first
        # use because of a bad network moment. Heredoc uses single-
        # quoted PYEOF so $vars inside Python aren't expanded by the
        # shell.
        emit_progress 80 "Downloading speech model (~350 MB, may take 1–2 minutes)..."
        if ! "$SERVICES_DIR/.venv/bin/python3" - <<'PYEOF'
import sys
from pathlib import Path
download_dir = Path.home() / ".local" / "share" / "kokoro"
download_dir.mkdir(parents=True, exist_ok=True)
files = ["kokoro-v1.0.onnx", "voices-v1.0.bin"]
needed = [f for f in files if not (download_dir / f).is_file()]
if not needed:
    print("[Relay Runner] Speech model files already present.")
    sys.exit(0)
print(f"[Relay Runner] Downloading {len(needed)} model file(s) to {download_dir}", file=sys.stderr)
try:
    from huggingface_hub import hf_hub_download
    for filename in needed:
        hf_hub_download(
            repo_id="fastrtc/kokoro-onnx",
            filename=filename,
            local_dir=str(download_dir),
        )
    print("[Relay Runner] Speech model download complete.", file=sys.stderr)
except Exception as e:
    print(f"[Relay Runner] Speech model download failed: {e}", file=sys.stderr)
    sys.exit(1)
PYEOF
        then
            echo ''
            echo "[Relay Runner] Failed to download speech model files."
            echo "[Relay Runner] Check internet connectivity and retry."
            exit 1
        fi
    fi

    if ! $CLAUDE_CLI_OK; then
        # voice_bridge.py spawns `claude -p ...` per spoken turn in the
        # default (non-relay) session mode, so a missing CLI dead-ends
        # the very first session. Anthropic ships a native installer at
        # claude.ai/install.sh that drops a binary at ~/.local/bin/claude
        # — no Node, no admin, no PATH gymnastics for non-admin users.
        # ProcessManager prepends ~/.local/bin to the launcher's PATH so
        # the just-installed binary is on PATH for python's
        # shutil.which("claude") lookup downstream.
        emit_progress 95 "Installing Claude Code CLI..."
        echo "[Relay Runner] Installing Claude Code CLI from claude.ai/install.sh..."
        if ! curl -fsSL https://claude.ai/install.sh | bash; then
            echo ''
            echo "[Relay Runner] Claude Code CLI install failed."
            echo "[Relay Runner] Check internet connectivity and retry, or install manually:"
            echo "    curl -fsSL https://claude.ai/install.sh | bash"
            exit 1
        fi
        if [ ! -x "$HOME/.local/bin/claude" ]; then
            echo "[Relay Runner] Claude Code installer ran but $HOME/.local/bin/claude is not executable."
            exit 1
        fi
    fi

    if ! $RELAY_SKILLS_OK; then
        # Runs after the Claude CLI install above so the .md files
        # always land into a working Claude environment. if-missing
        # mode preserves user edits — a force overwrite is reachable
        # via Settings → Reinstall (--install-skills flag).
        emit_progress 98 "Installing Claude Code skills..."
        install_skills if-missing
    fi

    if ! $RELAY_MCP_OK; then
        # Register the relay-actions MCP server with Claude Code at user
        # scope so screenshot / click / type tools are available in every
        # `claude` invocation, not just sessions started in this repo.
        #
        # find_mcp_binary resolves the absolute path to the helper Mach-O.
        # Bundled installs find it next to the main binary inside the .app;
        # dev runs from the repo find it in .build/{release,debug}/.
        # Idempotent: `claude mcp add` errors when the name already exists,
        # so we gate on the upfront RELAY_MCP_OK check above.
        emit_progress 99 "Registering MCP server..."
        __claude_bin=""
        if [ -x "$HOME/.local/bin/claude" ]; then
            __claude_bin="$HOME/.local/bin/claude"
        elif command -v claude >/dev/null 2>&1; then
            __claude_bin="$(command -v claude)"
        fi
        __mcp_bin=""
        # Bundled (Contents/SharedSupport/scripts → ../../MacOS/relay-actions-mcp).
        __bundled_mcp="$SCRIPT_DIR/../../MacOS/relay-actions-mcp"
        if [ -x "$__bundled_mcp" ]; then
            __mcp_bin="$(cd "$(dirname "$__bundled_mcp")" && pwd)/relay-actions-mcp"
        else
            for __cfg in release debug; do
                __dev_mcp="$SCRIPT_DIR/../.build/$__cfg/relay-actions-mcp"
                if [ -x "$__dev_mcp" ]; then
                    __mcp_bin="$(cd "$(dirname "$__dev_mcp")" && pwd)/relay-actions-mcp"
                    break
                fi
            done
        fi
        if [ -z "$__claude_bin" ]; then
            echo "[Relay Runner] Skipping MCP registration — claude CLI not found." >&2
        elif [ -z "$__mcp_bin" ]; then
            echo "[Relay Runner] Skipping MCP registration — relay-actions-mcp binary not found." >&2
            echo "[Relay Runner] Looked in $__bundled_mcp and .build/{release,debug}/." >&2
        else
            # `claude mcp add -s user` writes to ~/.claude.json. Non-fatal on
            # failure — voice features still work without the MCP server,
            # only the new Relay Actions tools become unavailable.
            if "$__claude_bin" mcp add -s user relay-actions -- "$__mcp_bin" >/dev/null 2>&1; then
                echo "[Relay Runner] Registered MCP server: relay-actions → $__mcp_bin"
            else
                echo "[Relay Runner] MCP server registration failed (non-fatal). Try manually:" >&2
                echo "    $__claude_bin mcp add -s user relay-actions -- $__mcp_bin" >&2
            fi
        fi
    fi

    emit_progress 100 "Setup complete."
    echo ''
    echo '[Relay Runner] Setup complete.'
    echo ''
fi

# -- Onboarding short-circuit: bootstrap is done, no voice bridge needed --
if $VENV_ONLY; then
    # Emit a terminal 100% marker so the SwiftUI bar fills regardless of
    # whether the install block above ran or was short-circuited (venv
    # already healthy on a re-run).
    emit_progress 100 "Ready."
    echo '[relay-bridge] Venv ready (--venv-only).'
    exit 0
fi

# -- Create FIFO --
[ -p "$VOICE_FIFO" ] || mkfifo "$VOICE_FIFO" 2>/dev/null || true

# -- Note: STT is now handled by the Relay Runner menu bar app --
# -- This script only starts the Python voice bridge in relay mode --
if ! pgrep -f 'relay-runner' > /dev/null 2>&1; then
    echo "[relay-bridge] Warning: Relay Runner app is not running. STT will not be available."
    echo "[relay-bridge] Start the Relay Runner menu bar app for speech-to-text."
fi

# -- Start voice bridge --
echo "[relay-bridge] Starting voice bridge..."
exec "$PYTHON" "$SERVICES_BUNDLE/voice_bridge.py" --config "$CONFIG_PATH" --relay "$@"
