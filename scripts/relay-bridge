#!/bin/bash
# relay-bridge -- Start voice I/O pipeline (STT sidecar + voice bridge).
#
# Usage:
#   relay-bridge                     # Normal mode: full voice terminal
#   relay-bridge --session <id>      # Resume a specific Claude session
#   relay-bridge --relay             # Relay mode: daemon for /relay-bridge slash command
#
# In relay mode, voice commands are written to /tmp/voice_cmd_ready for Claude
# to pick up, and TTS input is read from /tmp/tts_in.fifo.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# -- Paths --
SERVICES_DIR="$PROJECT_ROOT/services"
VOICE_FIFO="/tmp/voice_in.fifo"
BRIDGE_SOCK="/tmp/voice_bridge.sock"

CONFIG_DIR="${XDG_CONFIG_HOME:-}"
if [ -z "$CONFIG_DIR" ]; then
    if [ "$(uname)" = "Darwin" ]; then
        CONFIG_DIR="$HOME/Library/Application Support"
    else
        CONFIG_DIR="$HOME/.config"
    fi
fi
CONFIG_PATH="$CONFIG_DIR/relay-runner/config.toml"

# Export PROJECT_ROOT so the slash command can find us
export PROJECT_ROOT

# -- Kill any existing bridge (only one voice session at a time) --
if [ -S "$BRIDGE_SOCK" ]; then
    if pgrep -f 'voice_bridge.py' > /dev/null 2>&1; then
        echo "[relay-bridge] Stopping previous voice session..."
        # Try graceful shutdown first
        python3 -c "
import socket, os
s = socket.socket(socket.AF_UNIX, socket.SOCK_DGRAM)
try: s.sendto(b'shutdown', '$BRIDGE_SOCK')
except: pass
s.close()
" 2>/dev/null
        sleep 0.5
        # Force kill if still alive
        pkill -f 'voice_bridge.py' 2>/dev/null || true
        sleep 0.3
    fi
    rm -f "$BRIDGE_SOCK"
fi

# -- Ensure Python venv with dependencies --
PYTHON="$SERVICES_DIR/.venv/bin/python3"
if [ ! -x "$PYTHON" ]; then
    echo ''
    echo '╔══════════════════════════════════════════╗'
    echo '║  Relay Runner — First-time setup         ║'
    echo '║  Installing Python dependencies...       ║'
    echo '╚══════════════════════════════════════════╝'
    echo ''
    # Prefer a specific minor version with broad wheel coverage for our
    # deps (kokoro-onnx + transitive phonemizer/espeakng/onnxruntime).
    # The bare `python3` on Homebrew may point to a very new release
    # (e.g. 3.14) where some transitive wheels are still missing — so
    # we prefer 3.13/3.12/3.11 when they're installed, but fall back
    # to any Python >= 3.10 rather than rejecting the machine outright.
    VENV_PYTHON=""
    for p in \
        /opt/homebrew/bin/python3.13 /usr/local/bin/python3.13 python3.13 \
        /opt/homebrew/bin/python3.12 /usr/local/bin/python3.12 python3.12 \
        /opt/homebrew/bin/python3.11 /usr/local/bin/python3.11 python3.11 \
        /opt/homebrew/bin/python3 /usr/local/bin/python3 python3; do
        if command -v "$p" >/dev/null 2>&1 && \
           "$p" -c 'import sys; sys.exit(0 if sys.version_info[:2] >= (3,10) else 1)' 2>/dev/null; then
            VENV_PYTHON="$p"
            break
        fi
    done
    if [ -z "$VENV_PYTHON" ]; then
        echo "[Relay Runner] No compatible Python found (need 3.10+)."
        echo "Install with: brew install python@3.13"
        exit 1
    fi
    echo "Using $("$VENV_PYTHON" --version) at $VENV_PYTHON"
    "$VENV_PYTHON" -m venv "$SERVICES_DIR/.venv" && \
    "$SERVICES_DIR/.venv/bin/python3" -m pip install --upgrade pip && \
    "$SERVICES_DIR/.venv/bin/pip" install -r "$SERVICES_DIR/requirements.txt" && \
    echo '' && echo '[Relay Runner] Setup complete.' || \
    { echo ''; echo '[Relay Runner] Setup failed. Check errors above.'; exit 1; }
    echo ''
fi

# -- Create FIFO --
[ -p "$VOICE_FIFO" ] || mkfifo "$VOICE_FIFO" 2>/dev/null || true

# -- Note: STT is now handled by the Relay Runner menu bar app --
# -- This script only starts the Python voice bridge in relay mode --
if ! pgrep -f 'relay-runner' > /dev/null 2>&1; then
    echo "[relay-bridge] Warning: Relay Runner app is not running. STT will not be available."
    echo "[relay-bridge] Start the Relay Runner menu bar app for speech-to-text."
fi

# -- Start voice bridge --
echo "[relay-bridge] Starting voice bridge..."
exec "$PYTHON" "$SERVICES_DIR/voice_bridge.py" --config "$CONFIG_PATH" --relay "$@"
